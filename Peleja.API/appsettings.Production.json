{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NAuth": {
    "ApiURL": "${NAUTH_API_URL}",
    "BucketName": "Peleja",
    "JwtSecret": "${JWT_SECRET}"
  },
  "Tenants": {
    "emagine": {
      "ConnectionString": "${EMAGINE_CONNECTION_STRING}"
    },
    "peleja": {
      "ConnectionString": "${PELEJA_CONNECTION_STRING}"
    }
  },
  "GIPHY_API_KEY": "${GIPHY_API_KEY}",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:*",
        "Period": "1m",
        "Limit": 30
      }
    ]
  }
}
