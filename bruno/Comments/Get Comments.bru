meta {
  name: Get Comments
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/comments?pageUrl={{pageUrl}}&sortBy=recent&pageSize=15
  body: none
  auth: none
}

params:query {
  pageUrl: {{pageUrl}}
  sortBy: recent
  pageSize: 15
}

headers {
  X-Client-Id: {{clientId}}
}

vars:pre-request {
  pageUrl: https://peleja.com/demo
  clientId: 23c5ded3c7be46e78e8d1502fb46ff85
}
