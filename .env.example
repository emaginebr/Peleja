# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=peleja
CONNECTION_STRING=Host=db;Port=5432;Database=peleja;Username=postgres;Password=your_password_here

# NAuth
NAUTH_API_URL=http://nauth-api:80
JWT_SECRET=your_jwt_secret_key_here_at_least_64_characters_long_for_security
BUCKET_NAME=Peleja

# Giphy
GIPHY_API_KEY=your_giphy_api_key_here

# App
APP_PORT=5000
